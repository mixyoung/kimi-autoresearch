{
  "goal": "Increase Go test coverage to 80%",
  "scope": "**/*.go",
  "metric": "coverage percentage",
  "direction": "higher",
  "verify": "go test -cover ./... 2>&1 | grep -o 'coverage: [0-9.]*%' | head -1 | grep -o '[0-9.]*'",
  "guard": "go build ./... && go vet ./...",
  "iterations": 25,
  "target": 80,
  "loop_control": {
    "max_steps_per_turn": 50,
    "max_retries_per_step": 3,
    "max_ralph_iterations": 25
  },
  "agent_config": {
    "agent": "default"
  }
}

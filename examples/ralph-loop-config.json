{
  "goal": "Reduce TypeScript type errors to zero",
  "scope": "src/**/*.ts",
  "metric": "type error count",
  "verify": "tsc --noEmit 2>&1 | grep -c error",
  "direction": "lower",
  "guard": "npm run build",
  "iterations": 50,
  "target": 0,
  "loop_control": {
    "max_steps_per_turn": 30,
    "max_retries_per_step": 5,
    "max_ralph_iterations": 100
  },
  "agent_config": {
    "agent": "default",
    "agent_file": null
  }
}

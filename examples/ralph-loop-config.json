{
  "_comment": "无限迭代示例 - 不设置 iterations 或设为 0 则无限运行，直到目标达成或手动停止",
  "goal": "Reduce TypeScript type errors to zero",
  "scope": "src/**/*.ts",
  "metric": "type error count",
  "verify": "tsc --noEmit 2>&1 | grep -c error",
  "direction": "lower",
  "guard": "npm run build",
  "target": 0,
  "loop_control": {
    "max_steps_per_turn": 30,
    "max_retries_per_step": 5,
    "max_ralph_iterations": 0
  },
  "agent_config": {
    "agent": "default"
  }
}

{
  "goal": "Reduce Rust compile time by 20%",
  "scope": "src/**/*.rs",
  "metric": "compile time (seconds)",
  "direction": "lower",
  "verify": "cargo clean && time -p cargo build --release 2>&1 | grep real | awk '{print $2}'",
  "guard": "cargo test && cargo clippy -- -D warnings",
  "iterations": 15,
  "target": 0,
  "loop_control": {
    "max_steps_per_turn": 50,
    "max_retries_per_step": 3,
    "max_ralph_iterations": 15
  },
  "agent_config": {
    "agent": "default"
  }
}
